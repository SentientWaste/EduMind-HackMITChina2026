<Application xmlns="https://github.com/avaloniaui"
             xmlns:converters="using:EduMindAI.Converters"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EduMindAI.App"
             RequestedThemeVariant="Light"
             xmlns:local="using:EduMindAI.Views"
             xmlns:sty="using:FluentAvalonia.Styling"          
			 xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:uip="clr-namespace:FluentAvalonia.UI.Controls.Primitives;assembly=FluentAvalonia">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
           <local:BoolToAlignmentConverter x:Key="BoolToAlignment"/>
           <converters:IsZeroToBoolConverter x:Key="IsZeroToBool"/>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <sty:FluentAvaloniaTheme/>
    </Application.Styles>
</Application>