<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:EduMindAI.Views"
             xmlns:sty="using:FluentAvalonia.Styling"          
             xmlns:converters="using:EduMindAI.UI.Converters"
			 xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:uip="clr-namespace:FluentAvalonia.UI.Controls.Primitives;assembly=FluentAvalonia"
             x:Class="EduMindAI.App"
             RequestedThemeVariant="Light">
    
    <Application.Styles>
        <FluentTheme />
        <sty:FluentAvaloniaTheme/>
    </Application.Styles>
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://EduMindAI/UI/Themes/TitleBarTheme.axaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:IsZeroToBoolConverter x:Key="IsZeroToBoolConverter"/>
            <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
            <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>