<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:EduMindAI.ViewModel"
             xmlns:local="using:EduMindAI"
             xmlns:md="using:Markdown.Avalonia"
             xmlns:converters="using:EduMindAI.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EduMindAI.Views.HomeView"
             x:DataType="vm:HomeViewModel">
    <UserControl.Resources>
        <SolidColorBrush x:Key="UserBubbleForegroundBrush" Color="White"/>
        <SolidColorBrush x:Key="UserBubbleBackgroundBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="TimeStampForegroundBrush" Color="#666666"/>
        <SolidColorBrush x:Key="ChatInputBackgroundBrush" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="AssistantBubbleBackgroundBrush" Color="#e5e5e5"/>
        <SolidColorBrush x:Key="AssistantBubbleForegroundBrush" Color="#2D2D2D"/>
    </UserControl.Resources>
    
    <UserControl.Styles>
        <!-- 消息气泡样式 - 用户消息（右） -->
        <Style Selector="Border.UserMessage">
            <Setter Property="Background" Value="{DynamicResource UserBubbleBackgroundBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="CornerRadius" Value="16 16 4 16"/>
            <Setter Property="Padding" Value="16 12"/>
            <Setter Property="MaxWidth" Value="500"/>
        </Style>
        
        <!-- 消息气泡样式 - AI消息（左） -->
        <Style Selector="Border.AIMessage">
            <Setter Property="Background" Value="{DynamicResource AssistantBubbleBackgroundBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="CornerRadius" Value="16 16 16 4"/>
            <Setter Property="Padding" Value="16 12"/>
            <Setter Property="MaxWidth" Value="500"/>
        </Style>
        
        <!-- 消息文本样式 - 用户 -->
        <Style Selector="TextBlock.UserText">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource UserBubbleForegroundBrush}"/>
        </Style>
        
        <!-- 消息文本样式 - AI -->
        <Style Selector="TextBlock.AIText">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource AssistantBubbleForegroundBrush}"/>
        </Style>
        
        <!-- 时间戳样式 -->
        <Style Selector="TextBlock.Timestamp">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TimeStampForegroundBrush}"/>
        </Style>
        
        <!-- 输入框样式 -->
        <Style Selector="TextBox.ChatInput">
            <Setter Property="Background" Value="{DynamicResource ChatInputBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxHeight" Value="100"/>
            <Setter Property="Watermark" Value="输入消息..."/>
        </Style>

        <!-- 复制按钮 -->
        <Style Selector="Button.CopyButton">
            <Setter Property="Background" Value="red"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Setter.Value>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    </Transitions>
                </Setter.Value>
            </Setter>
        </Style>
        
        
        <!-- 输入框焦点样式 -->
        <Style Selector="TextBox.ChatInput:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource UserMessageBrush}"/>
        </Style>
        
        <!-- AI 思考状态样式 -->
        <Style Selector="TextBlock.ThinkingText">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TimestampBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <!-- 界面布局 -->
    <Grid RowDefinitions="* auto auto">
        <!-- 聊天消息列表 -->
        <ScrollViewer Padding="24"
                      Name="MessageScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Grid.Row="0">      
            <StackPanel>
                <!--这里本因用 DataTemplates 重写，但我力竭了就算了-->
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- 用户消息 -->
                                <Border Classes="UserMessage"
                                        IsVisible="{Binding IsUser}">
                                    <TextBlock Classes="UserText"
                                               TextWrapping="Wrap"
                                               Text="{Binding Content}"
                                               Grid.Column="0" 
                                               xml:space="preserve"/>
                                </Border>
                                
                                <!-- AI 消息 -->
                                <Border Classes="AIMessage"
                                        IsVisible="{Binding !IsUser}"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <TextBlock Classes="AIText"
                                               TextWrapping="Wrap"
                                               Text="{Binding Content}"
                                               xml:space="preserve"
                                               Grid.Column="0" />
                                </Border>
                                
                                <!-- ToolBar -->
                                <Grid Margin="0 4 0 16"
                                      ColumnDefinitions="auto 1 auto"
                                      HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignmentConverter}}">                                        
                                    <Button Padding="4"
                                            CommandParameter="{Binding}"
                                            Theme="{StaticResource TransparentButton}"
                                            Command="{Binding $parent[UserControl].DataContext.CopyMessageCommand}"
                                            Grid.Column="0">
                                        <ui:SymbolIcon Symbol="Copy" FontSize="18"/>
                                    </Button>

                                    <Border Width="1"
                                            Margin="4 2 8 2"
                                            VerticalAlignment="Stretch"
                                            Background="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                            Grid.Column="1"/>

                                    <TextBlock Classes="Timestamp"
                                               Text="{Binding Timestamp}"
                                               Grid.Column="2"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- AI 思考状态 -->
                <Border  HorizontalAlignment="Left"
                         IsVisible="{Binding IsAIThinking}">
                    <StackPanel Spacing="0" Orientation="Horizontal">
                        <ui:ProgressRing Height="20" 
                                         IsIndeterminate="{Binding IsAIThinking}"/>

                        <TextBlock Text="AI 正在回复..." 
                                  Classes="ThinkingText"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 底部输入区域 -->
        <Border Grid.Row="1" 
                Background="Transparent"
                Padding="24 24 24 0">
            
            <Grid ColumnDefinitions="auto * auto">
                <!-- 输入框 -->
                <TextBox Name="MessageInput"
                         KeyDown="OnMessageInputKeyDown"
                         VerticalContentAlignment="Center"
                         Text="{Binding CurrentMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="1">
                    <TextBox.InnerLeftContent>
                        <Button Width="40"
                                Height="40"
                                Margin="10 8"
                                CornerRadius="20"
                                Command="{Binding ToggleListeningCommand}"
                                Theme="{StaticResource TransparentButton}">
                            <ui:SymbolIcon FontSize="24"
                                           Symbol="Microphone"/>
                        </Button>
                    </TextBox.InnerLeftContent>
                    
                    <TextBox.InnerRightContent>
                        <Button Width="40"
                                Height="40"
                                Margin="10 8"
                                CornerRadius="20"
                                VerticalContentAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding SendMessageCommand}"
                                Theme="{StaticResource TransparentButton}">
                            <ui:SymbolIcon Symbol="Send"
                                           FontSize="24"
                                           HorizontalAlignment="Right"/>
                        </Button>
                    </TextBox.InnerRightContent>
                </TextBox>
            </Grid>
        </Border>

        <TextBlock FontSize="10"
                   Margin="0 4 0 24"
                   HorizontalAlignment="Center"
                   Text="内容由AI生成，可能不准确，请注意核实"
                   Grid.Row="2"/>
    </Grid>
</UserControl>