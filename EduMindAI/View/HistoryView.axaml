<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:EduMindAI.ViewModel"
             xmlns:local="using:EduMindAI.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EduMindAI.HistoryView"
             x:DataType="vm:HistoryViewModel">
    
    <!-- 在资源里定义画刷，方便后端修改 -->
    <UserControl.Resources>
<!--        <SolidColorBrush x:Key="DateHeaderBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardTextBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="PreviewTextBrush" Color="#666666"/>
        <SolidColorBrush x:Key="TimeTagBackgroundBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="TimeTagTextBrush" Color="#666666"/>
        <SolidColorBrush x:Key="SearchBoxBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="White"/>
        <SolidColorBrush x:Key="SearchBoxBorderBrush" Color="#E6E6E6"/>-->

        <DataTemplate x:Key="SessionCardTemplate" x:DataType="vm:SessionItem">
            <Border Classes="SessionCard"
                    PointerPressed="OnSessionClicked"
                    Tag="{Binding Id}">
                
                <!-- 右键菜单 -->
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="删除"
                                  Classes="DeleteItem"
                                  Tag="{Binding Id}"
                                  Click="OnDeleteSessionClicked"/>
                    </ContextMenu>
                </Border.ContextMenu>
                
                <Grid RowDefinitions="auto auto" 
                      ColumnDefinitions="* auto">
  
                    <TextBlock Text="{Binding Title}" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Grid.Row="0" />
                    
                    <Border Classes="TimeTag"
                            Grid.Row="0"
                            Grid.Column="1">
                        <TextBlock FontSize="10"
                                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                   Text="{Binding Time}" />
                    </Border>
  
                    <TextBlock Grid.Row="1" 
                              Grid.ColumnSpan="2"
                              FontSize="14" 
                              Text="{Binding Preview}"
                              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                              Margin="0,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>        
        <!-- 会话卡片样式 -->
        <Style Selector="Border.SessionCard">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0 0 0 12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 2 4 rgba(0,0,0,0.05)"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>

        <!-- 鼠标悬停时增加左边距和阴影 -->
        <Style Selector="Border.SessionCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BoxShadow" Value="0 2 8 rgba(0,0,0,0.1)"/>
        </Style>
        
        <!-- 预览文本样式 -->
        <Style Selector="TextBlock.PreviewText">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
        </Style>
        
        <!-- 时间标签样式 -->
        <Style Selector="Border.TimeTag">
            <Setter Property="Padding" Value="4 2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Background" Value="{DynamicResource ControlStrongFillColorDefaultBrush}"/>
        </Style>
        
        <!-- 搜索框样式 -->
        <Style Selector="TextBox.SearchBox">
            <Setter Property="Background" Value="{DynamicResource SearchBoxBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBoxBorderBrush}"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        
        <!-- 右键菜单样式 -->
        <Style Selector="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        
        <Style Selector="MenuItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>
        
        <Style Selector="MenuItem.DeleteItem">
            <Setter Property="Foreground" Value="#FF4444"/>
        </Style>
        
        <Style Selector="MenuItem.DeleteItem:pointerover">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
    
    <Grid RowDefinitions="auto *">
        <!-- 顶部搜索栏 -->
        <Border Padding="24 16"
                Grid.Row="0">
            
            <Grid ColumnDefinitions="* auto auto">
                <TextBox Grid.Column="0"
                         Name="SearchBox"
                         Watermark="搜索历史会话..."
                         Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                
                <!-- 导出历史按钮 -->
                <Button Margin="8 0 0 0"
                        Command="{Binding ExportCommand}"
                        Grid.Column="2" >
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <ui:SymbolIcon Symbol="Download" FontSize="14"/>
                        <TextBlock Text="导出历史"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
        <ScrollViewer Padding="24 0"
                      Name="SessionScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Grid.Row="1">   
            <StackPanel>
                <!-- 今日 -->
                <TextBlock Text="今天"
                           Margin="0 0 0 12"
                           Theme="{StaticResource BodyStrongTextBlockStyle}"/>
                
                <ItemsControl Name="TodayList"
                              ItemsSource="{Binding TodaySessions}"
                              ItemTemplate="{StaticResource SessionCardTemplate}"/>
                
                <!-- 昨天 -->
                <TextBlock Text="昨天"
                           Margin="0 0 0 12"
                           Theme="{StaticResource BodyStrongTextBlockStyle}"/>
                
                <ItemsControl Name="YesterdayList" 
                              ItemsSource="{Binding YesterdaySessions}"
                              ItemTemplate="{StaticResource SessionCardTemplate}"/>
                
                <!-- 更早 -->
                <TextBlock Text="更早"
                           Margin="0 0 0 12"
                           Theme="{StaticResource BodyStrongTextBlockStyle}"/>
                
                <ItemsControl Name="EarlierList" 
                              ItemsSource="{Binding EarlierSessions}"
                              ItemTemplate="{StaticResource SessionCardTemplate}"/>
                
                <!-- 空状态 -->
                <Border IsVisible="{Binding IsEmpty}"
                        Height="300"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" 
                              VerticalAlignment="Center"
                              Spacing="10">
                        <ui:SymbolIcon Symbol="Zoom" 
                                      FontSize="48"
                                      Foreground="{StaticResource PreviewTextBrush}"/>
                        <TextBlock Text="暂无历史会话" 
                                  FontSize="16"
                                  Foreground="{StaticResource PreviewTextBrush}"/>
                        <TextBlock Text="开始对话后，记录会自动保存" 
                                  FontSize="13"
                                  Foreground="{StaticResource PreviewTextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>